# Hermes for Reticulum — Environment Configuration
# Copy this file to .env and customize

# ═══════════════════════════════════════════════════════
# Reticulum Configuration
# ═══════════════════════════════════════════════════════

# Display name announced on the mesh network
RETICULUM_DISPLAY_NAME="Hermes for Reticulum"

# Path to store LXMF messages and identity
RETICULUM_STORAGE=~/.lxmf/storage

# LXMF stamp cost (bandwidth throttle — 8 is standard)
RETICULUM_STAMP_COST=8

# Path to Reticulum config directory (leave empty for default ~/.reticulum)
# RETICULUM_CONFIG=

# ═══════════════════════════════════════════════════════
# Hermes Integration
# ═══════════════════════════════════════════════════════

# Path to hermes CLI binary
HERMES_BIN=hermes

# Timeout for Hermes processing (seconds)
HERMES_TIMEOUT=300

# ═══════════════════════════════════════════════════════
# Access Control
# ═══════════════════════════════════════════════════════

# Allow all users to message the agent (true/false)
HERMES_RETICUM_ALLOW_ALL=true

# Comma-separated LXMF hashes of allowed users (used when ALLOW_ALL=false)
# HERMES_RETICUM_ALLOWED_USERS=

# Comma-separated LXMF hashes of blocked users
# HERMES_RETICUM_BLOCKED_USERS=
