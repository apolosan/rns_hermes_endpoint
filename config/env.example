# Hermes for Reticulum — Environment Configuration
# Copy this file to .env and customize

# ═══════════════════════════════════════════════════════
# Reticulum Configuration
# ═══════════════════════════════════════════════════════

# Display name announced on the mesh network
RETICULUM_DISPLAY_NAME="Hermes for Reticulum"

# Path to store LXMF messages and identity
RETICULUM_STORAGE=~/.lxmf/storage

# LXMF stamp cost (bandwidth throttle — 8 is standard)
RETICULUM_STAMP_COST=8

# Path to Reticulum config directory (leave empty for default ~/.reticulum)
# RETICULUM_CONFIG=

# ═══════════════════════════════════════════════════════
# Hermes Integration
# ═══════════════════════════════════════════════════════

# Path to hermes CLI binary (auto-detected if empty)
# HERMES_BIN=

# Timeout for Hermes processing (seconds)
HERMES_TIMEOUT=300

# ═══════════════════════════════════════════════════════
# Access Control
# ═══════════════════════════════════════════════════════
#
# SECURITY: Default is allowlist mode (ALLOW_ALL=false).
# Only addresses listed in ALLOWED_USERS can interact with the agent.
# Unauthorized requests receive an automatic rejection message
# WITHOUT invoking Hermes (zero token consumption).

# Allow all users to message the agent (true/false)
HERMES_RETICUM_ALLOW_ALL=false

# Comma-separated LXMF hashes of allowed users (32 hex chars each)
# Example: HERMES_RETICUM_ALLOWED_USERS=aa11bb22...,cc33dd44...,ee55ff66...
HERMES_RETICUM_ALLOWED_USERS=

# Comma-separated LXMF hashes of blocked users (takes priority over allowlist)
# HERMES_RETICUM_BLOCKED_USERS=
