[Unit]
Description=Hermes for Reticulum — AI agent bridge on the mesh network
Documentation=https://github.com/apolosan/rns_hermes_endpoint
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/opt/rns_hermes_endpoint
Environment=HOME=/opt/rns_hermes_endpoint
EnvironmentFile=/opt/rns_hermes_endpoint/.env
ExecStart=/opt/rns_hermes_endpoint/venv/bin/hermes-reticulum run
Restart=on-failure
RestartSec=10
StartLimitBurst=5
StartLimitIntervalSec=300

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/rns_hermes_endpoint/.lxmf /opt/rns_hermes_endpoint/.reticulum /opt/rns_hermes_endpoint/.hermes
PrivateTmp=yes

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes-reticulum

[Install]
WantedBy=multi-user.target
